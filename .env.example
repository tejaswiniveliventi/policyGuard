# === APPLICATION ===
DEBUG=false
ENVIRONMENT=development
APP_NAME=PolicyGuard
APP_VERSION=0.1.0

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=  # Optional, for API authentication

# === DATABASE (Supabase) ===
# Get this from Supabase project settings
DATABASE_URL=postgresql://user:password@host:port/database

# === LLM CONFIGURATION ===
LLM_PROVIDER=groq  # Options: groq, together, openai, anthropic, azure
LLM_MODEL=mixtral-8x7b-32768
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2000

# === LLM API KEYS ===
# Only set the key for your chosen provider
GROQ_API_KEY=
TOGETHER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_API_KEY=
AZURE_ENDPOINT=

# === WEB INTELLIGENCE ===
BRIGHT_DATA_API_KEY=

# === NOTIFICATIONS ===
# Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Slack (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# === SUPABASE (Frontend) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# === LOGGING ===
LOG_LEVEL=INFO
SQL_ECHO=false